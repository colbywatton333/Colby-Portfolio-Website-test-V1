  "bass-speaker": {
    "canvasWidth": 1200,
    "pages": [
      {
        "elements": [
          {
            "type": "text",
            "id": "el-mndppknu-xwmbm",
            "field": "description",
            "content": "I wanted to see if I could create a minimalist approach to a subwoofer. Creating a simple box with large radius round-over edges, responding to the soft form of the subwoofer shape. The result is a monochrome SUB.",
            "x": 0,
            "y": 0,
            "width": 33.499994913736984,
            "height": 133.33328247070312,
            "zIndex": 1,
            "style": {
              "fontSize": "clamp(11px, 1.1vw, 16px)",
              "fontWeight": "400",
              "color": "var(--text)",
              "lineHeight": "1.7"
            }
          },
          {
            "type": "text",
            "id": "el-mndppknu-kw3yf",
            "field": "materials",
            "content": "MATERIALS\nCNC cut Baltic Birch plywood, epoxy, rubber feet, 3D prints, paint, 18\" subwoofer components, lifting hardware",
            "x": 0.05555725097656249,
            "y": 144.00003051757812,
            "width": 33.55555725097656,
            "height": 112.66665649414062,
            "zIndex": 1,
            "style": {
              "fontSize": "clamp(10px, 1vw, 16px)",
              "fontWeight": "400",
              "color": "var(--text)",
              "lineHeight": "1.5"
            }
          },
          {
            "type": "text",
            "id": "el-mndppknu-0jxgu",
            "field": "process",
            "content": "PROCESS\nCAD Design (Fusion 360) — creating a 3D model with recessed and interlocking joints with tight tolerances to fit perfectly together. CNC cutting the plywood, assembly, sanding, painting, subwoofer and sound component installation.",
