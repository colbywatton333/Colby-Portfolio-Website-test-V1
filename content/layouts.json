  "__about__": {
    "canvasWidth": 1200,
    "pageHeight": null,
    "pages": [
      {
        "elements": [
          {
            "type": "text",
            "id": "el-mndzpc8y-c64h8",
            "field": "section-title",
            "content": "Biography",
            "x": 0,
            "y": 0,
            "width": 40,
            "height": "auto",
            "zIndex": 1,
            "style": {
              "fontSize": "clamp(24px, 3vw, 48px)",
              "fontWeight": "700",
              "color": "var(--text)",
              "letterSpacing": "-0.02em",
              "lineHeight": "1.1"
            }
          },
          {
            "type": "text",
            "id": "el-mndzpc8y-210cy",
            "field": "bio-text",
            "content": "My name is Colby I am a Vancouver-based industrial designer with a multidisciplinary background in art, fabrication, and prototyping. I graduated from Emily Carr University in 2024 with a Bachelor of Fine Arts, and since then I have worked with private clients while continuing to develop independent projects and entrepreneurial ventures.",
            "x": 0,
            "y": 80,
            "width": 45,
            "height": "auto",
            "zIndex": 1,
            "style": {
              "fontSize": "clamp(11px, 1.1vw, 18px)",
              "fontWeight": "400",
              "color": "var(--text-mid)",
              "lineHeight": "1.75"
            }
          },
          {
            "type": "text",
            "id": "el-mndzpc8y-5txym",
            "field": "bio-text",
            "content": "My practice is centered on the design and development of functional objects, with a particular interest in material processes, mechanical systems, and iterative prototyping. I approach design as both a creative and technical discipline, combining conceptual thinking with a strong understanding of how products are manufactured, tested, and refined. My interests evolved from artistic exploration in painting and sculpture toward designing functional objects. Through experimentation with materials, prototyping, and hands-on making, I developed a strong interest in industrial design and the process of bringing ideas into physical form.",
            "x": 0,
            "y": 300,
            "width": 45,
            "height": "auto",
            "zIndex": 1,
            "style": {
              "fontSize": "clamp(11px, 1.1vw, 18px)",
              "fontWeight": "400",
              "color": "var(--text-mid)",
              "lineHeight": "1.75"
            }
          }
        ]
      },
